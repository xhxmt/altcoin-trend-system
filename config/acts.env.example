ACTS_DATABASE_URL=postgresql+psycopg://tfisher@/altcoin_trend
# ACTS_OUTPUT_ROOT defaults to <project-root>/artifacts when run from source,
# or ~/.local/share/altcoin-trend-system/artifacts after install.
# ACTS_OUTPUT_ROOT=
ACTS_DEFAULT_EXCHANGES=binance,bybit
ACTS_QUOTE_ASSET=USDT
ACTS_MIN_QUOTE_VOLUME_24H=5000000
ACTS_MIN_LISTING_DAYS=60
ACTS_BOOTSTRAP_LOOKBACK_DAYS=90
ACTS_SNAPSHOT_LOOKBACK_DAYS=31
ACTS_STALE_MARKET_SECONDS=3600
ACTS_SIGNAL_INTERVAL_SECONDS=60
ACTS_DAEMON_FAILURE_BACKOFF_MAX_SECONDS=300
ACTS_ALERT_COOLDOWN_SECONDS=14400
ACTS_TELEGRAM_BOT_TOKEN=
ACTS_TELEGRAM_CHAT_ID=
# Leave ACTS_SYMBOL_ALLOWLIST empty for full-market mode.
# ACTS_SYMBOL_BLOCKLIST applies in both full-market and allowlist mode.
ACTS_SYMBOL_ALLOWLIST=
ACTS_SYMBOL_BLOCKLIST=
